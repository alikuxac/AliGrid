# Access Control Whitelist (comma separated list of user IDs)
VITE_ALLOWED_TELEGRAM_IDS=1234567890,another_id
VITE_ALLOWED_DISCORD_IDS=123456789012345678,another_id

# Global access password for simple Web locking (Optional)
VITE_WEB_ACCESS_PASSWORD=change_me

# Cloud Server API Base URL (Do not end with a slash)
VITE_API_BASE_URL=http://localhost:8787

