{
    "name": "aligrid-server",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:generate": "drizzle-kit generate",
        "db:seed:nodes": "wrangler d1 execute ALIGRID_DB --local --file=seeds/v0.1.0/nodes.sql",
        "db:seed:edges": "wrangler d1 execute ALIGRID_DB --local --file=seeds/v0.1.0/edge_costs.sql",
        "db:seed": "npm run db:seed:nodes && npm run db:seed:edges"
    },
    "dependencies": {
        "drizzle-orm": "^0.33.0",
        "hono": "^4.12.8"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20241205.0",
        "drizzle-kit": "^0.24.0",
        "wrangler": "^3.111.0"
    }
}