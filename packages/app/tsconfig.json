{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@aligrid/engine": ["../engine/src/index.ts"],
            "@aligrid/schema": ["../schema/src/index.ts"],
            "@aligrid/ui": ["../ui/src/index.ts"]
        },
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "src"
    ]
}